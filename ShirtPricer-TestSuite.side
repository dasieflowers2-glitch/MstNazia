  "suites": [
    {
      "id": "Valid-Customer-Orders",
      "name": "Valid Customer Orders",
      "tests": ["BB-01","BB-02","BB-03","BB-04","BB-05"]
    },
    {
      "id": "Representative-Values",
      "name": "Representative Values",
      "tests": ["BB-06","BB-07","BB-08","BB-09"]
    },
    {
      "id": "Boundary-Tests",
      "name": "Boundary Tests",
      "tests": ["BB-10","BB-11","BB-12","BB-13","BB-14"]
    },
    {
      "id": "Invalid-Numeric",
      "name": "Invalid Numeric",
      "tests": ["BB-15","BB-16","BB-17","BB-18"]
    },
    {
      "id": "Invalid-Input",
      "name": "Invalid Input",
      "tests": ["BB-19","BB-20","BB-21","BB-22","BB-23"]
