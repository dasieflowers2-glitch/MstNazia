        { "command": "check", "target": "name=collar", "value": "" },
        { "command": "check", "target": "name=sleeve", "value": "" },
        { "command": "select", "target": "name=currency", "value": "label=Euro" },
        { "command": "assertText", "target": "css=p", "value": "Your price is 92.33 Euro" }
      ]
    },

