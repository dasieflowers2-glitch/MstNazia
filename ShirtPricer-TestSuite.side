{
  "id": "ShirtPricer-BlackBox-Suite",
  "version": "2.0",
  "name": "ShirtPricer BlackBox Suite",
  "url": "http://localhost:8080",
  "tests": [

    {
      "id": "BB-01",
      "name": "BB-01 Standard Shirt",
      "commands": [
        { "command": "open", "target": "/ShirtPricer/", "value": "" },
        { "command": "setWindowSize", "target": "1025x729", "value": "" },
        { "command": "type", "target": "name=waist", "value": "34" },
        { "command": "type", "target": "name=neck", "value": "32" },
        { "command": "click", "target": "css=input[type=\"submit\"]", "value": "" },
        { "command": "assertText", "target": "css=p", "value": "Your price is 97.92 US Dollar" }
      ]
    },

    {
      "id": "BB-02",
      "name": "BB-02 Collar Shirt",
      "commands": [
