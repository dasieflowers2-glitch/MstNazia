{
  "tests": [

    {
      "id": "BB-10",
      "name": "BB-10 Minimum Boundary",
      "commands": [
        { "command": "open", "target": "/ShirtPricer/", "value": "" },
        { "command": "type", "target": "name=waist", "value": "1" },
        { "command": "type", "target": "name=neck", "value": "1" },
        { "command": "click", "target": "css=input[type=\"submit\"]", "value": "" },
        { "command": "verifyText", "target": "css=p", "value": "(?i).*error.*" }
      ]
    },

